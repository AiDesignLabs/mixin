{
  "name": "@mixin/components",
  "version": "0.0.1-alpha.1",
  "private": true,
  "description": "Vue components for Mixin 2D/3D hybrid scenes",
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./*": "./*"
  },
  "scripts": {
    "build": "vue-tsc --noEmit --skipLibCheck && vp build",
    "build:types": "vue-tsc --declaration --emitDeclarationOnly",
    "preview": "vp preview"
  },
  "dependencies": {
    "@mixin/runtime": "workspace:*",
    "three": "^0.180.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@types/three": "^0.180.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "typescript": "^5.7.2",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vue-router": "^4.6.4",
    "vue-tsc": "^2.1.10"
  },
  "peerDependencies": {
    "vue": "^3.5.0",
    "vue-router": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "vue-router": {
      "optional": true
    }
  }
}
