{
  "name": "@wendraw/ui",
  "version": "0.0.1-alpha.1",
  "private": true,
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./*": "./*"
  },
  "scripts": {
    "build": "vue-tsc --noEmit --skipLibCheck && vp build",
    "build:types": "vue-tsc --declaration --emitDeclarationOnly",
    "preview": "vp preview"
  },
  "dependencies": {
    "@wendraw/lib": "workspace:*",
    "@wendraw/lib2": "workspace:*",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.5",
    "typescript": "^5.7.2",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vue-tsc": "^2.1.10"
  },
  "peerDependencies": {
    "vue": "^3.2.47"
  }
}
